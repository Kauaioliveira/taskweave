# Database (Docker Compose default)
DATABASE_URL="postgresql://taskweave:taskweave@localhost:5432/taskweave"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"

# GitHub OAuth App (Authorization callback: http://localhost:3000/api/auth/callback/github)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Public origin for Auth.js (callbacks, emails). Local dev: http://localhost:3000 — production: https://your-domain
AUTH_URL="http://localhost:3000"

# Trust reverse-proxy host headers (typical on Vercel)
AUTH_TRUST_HOST="true"

# Optional: same public URL for client-side absolute links if you add them later
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: E2E / CI only — enables Credentials provider + seed data (never enable in production)
# E2E_TEST="1"
# E2E_PASSWORD="change-me-in-ci-only"
