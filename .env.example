# Database (Docker Compose default)
DATABASE_URL="postgresql://taskweave:taskweave@localhost:5432/taskweave"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"

# GitHub OAuth App (Authorization callback: http://localhost:3000/api/auth/callback/github)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Public URL (production)
AUTH_TRUST_HOST="true"

# Optional: E2E / CI only — enables Credentials provider + seed user (never enable in production)
# E2E_TEST="1"
# E2E_PASSWORD="change-me-in-ci-only"
